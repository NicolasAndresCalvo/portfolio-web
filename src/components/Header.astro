---
const path = Astro.url.pathname;
const isActive = (href) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/"><span class="brand__mark">N</span><span>Nicolás Andrés Calvo</span></a>
    <nav class="nav">
      <a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a>
      <a href="/cases" aria-current={isActive('/cases') ? 'page' : undefined}>Cases</a>
      <a href="/tags" aria-current={isActive('/tags') ? 'page' : undefined}>Topics</a>
      <a href="/certifications" aria-current={isActive('/certifications') ? 'page' : undefined}>Certs</a>
      <a href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a>
    </nav>
  </div>
</header>
