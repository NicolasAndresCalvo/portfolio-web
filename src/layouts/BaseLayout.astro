---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = 'Nicolás Andrés Calvo', description = 'Cloud / DevOps Engineer. Production war-stories and architecture case studies.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main class="wrap">
      <slot />
    </main>
    <Footer />

    <script>
      // Render any ```mermaid blocks (converted to <pre class="mermaid"> at build time).
      import mermaid from 'mermaid';
      mermaid.initialize({ startOnLoad: true, theme: 'dark', securityLevel: 'loose' });
    </script>
  </body>
</html>
