---
import BaseLayout from '../layouts/BaseLayout.astro';

const focus = [
  {
    title: "Cloud architecture on AWS",
    body: "Designing services on ECS Fargate and serverless, with managed data, secrets and event-driven backbones around stateless, disposable compute.",
  },
  {
    title: "Infrastructure as Code & GitOps",
    body: "Reusable Terraform modules and pipelines that plan on a PR and apply themselves on merge, authenticated with short-lived OIDC roles, no static keys.",
  },
  {
    title: "Migrations, cost & reliability",
    body: "Zero-downtime cross-region moves, cutting infrastructure spend, and making systems observable, with the trade-offs written down honestly.",
  },
];

const stack = [
  "AWS", "ECS Fargate", "Terraform", "Kubernetes", "GitHub Actions",
  "Docker", "CloudFront", "Aurora / PostgreSQL", "CI/CD", "Observability",
];
---
<BaseLayout title="About · Nicolás Andrés Calvo" description="Cloud / DevOps engineer working on AWS, Terraform and Kubernetes.">
  <section class="about">
    <header class="about-hero">
      <img class="avatar" src="/profile.jpg" width="128" height="128" alt="Nicolás Andrés Calvo" />
      <div class="about-hero__text">
        <h1>Nicolás Andrés Calvo</h1>
        <p class="role">Cloud / DevOps Engineer</p>
        <p class="lead">
          I turn fragile, expensive systems into stateless, disposable and observable ones, on AWS,
          with Terraform and Kubernetes. I care about the decisions behind the work, not just the diagram.
        </p>
        <nav class="links">
          <a href="https://github.com/NicolasAndresCalvo">GitHub</a>
          <a href="https://www.linkedin.com/in/nicolas-andres-calvo/">LinkedIn</a>
          <a href="https://www.credly.com/users/nicolas-andres-calvo/badges">Credly</a>
          <a href="mailto:nicolas.andres.calvo.engineer@gmail.com">Email</a>
        </nav>
      </div>
    </header>

    <h2>What I focus on</h2>
    <div class="cards">
      {focus.map((f) => (
        <article class="card">
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </article>
      ))}
    </div>

    <h2>Tools I work with</h2>
    <ul class="pills">
      {stack.map((s) => <li>{s}</li>)}
    </ul>

    <h2>Certifications</h2>
    <p class="muted">My verified badges live on <a href="https://www.credly.com/users/nicolas-andres-calvo/badges" rel="me">Credly</a>.</p>

    <h2>Get in touch</h2>
    <p class="muted">Open to interesting cloud and platform work.</p>
    <a class="cta" href="mailto:nicolas.andres.calvo.engineer@gmail.com">nicolas.andres.calvo.engineer@gmail.com</a>
  </section>
</BaseLayout>

<style>
  .about { padding: 2.5rem 0 1rem; }
  .about h2 { font-size: 1.3rem; margin: 2.5rem 0 1rem; }

  .about-hero { display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
  .avatar { border-radius: 50%; border: 2px solid var(--border); object-fit: cover; flex-shrink: 0; }
  .about-hero__text { flex: 1; min-width: 260px; }
  .about-hero h1 { margin: 0; font-size: 1.9rem; }
  .role { margin: .25rem 0 .75rem; color: var(--accent); font-weight: 600; }
  .lead { margin: 0 0 1rem; color: var(--fg-muted); font-size: 1.05rem; line-height: 1.6; }
  .links a { margin-right: 1.1rem; font-size: .95rem; }

  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
  .card { border: 1px solid var(--border); background: var(--bg-soft); border-radius: var(--radius); padding: 1.1rem 1.2rem; }
  .card h3 { margin: 0 0 .5rem; font-size: 1.05rem; }
  .card p { margin: 0; color: var(--fg-muted); font-size: .95rem; line-height: 1.55; }

  .pills { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: .5rem; }
  .pills li { background: var(--accent-soft); color: var(--accent); border-radius: 999px; padding: .25rem .8rem; font-size: .85rem; }

  .muted { color: var(--fg-muted); }
  .cta { display: inline-block; margin-top: .5rem; background: var(--accent); color: #0d1117; font-weight: 600; padding: .6rem 1.1rem; border-radius: var(--radius); }
  .cta:hover { text-decoration: none; filter: brightness(1.1); }
</style>
