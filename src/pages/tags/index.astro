---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const cases = await getCollection('cases', ({ data }) => import.meta.env.PROD ? !data.draft : true);
const counts = new Map();
for (const c of cases) {
  for (const t of c.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<BaseLayout title="Topics · Nicolás Andrés Calvo" description="Browse the writing by topic.">
  <section class="section">
    <h2>Topics</h2>
    <p style="color:var(--fg-muted)">Browse the writing by topic.</p>
    {tags.length === 0 ? (
      <p>No topics yet.</p>
    ) : (
      <div class="case-meta" style="font-size:.95rem">
        {tags.map(([tag, count]) => (
          <a class="tag" href={`/tags/${tag}`}>{tag} <span style="opacity:.7">({count})</span></a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
