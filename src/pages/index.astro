---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import certs from '../data/certifications.json';
import companies from '../data/companies.json';

const cases = (await getCollection('cases', ({ data }) => import.meta.env.PROD ? !data.draft : true))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = cases.slice(0, 3);
const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });

const activeCerts = certs.filter((c) => c.active);
---
<BaseLayout>
  <section class="hero">
    <div class="hero__text">
      <h1>Cloud &amp; DevOps Engineer architecting resilient infrastructure.</h1>
      <p class="lead">
        I design and run cloud platforms on AWS, with Terraform and Kubernetes, turning fragile,
        expensive systems into resilient, well-architected ones. Here I write up the real decisions
        and trade-offs behind that work.
      </p>
      <p class="links">
        <a href="/cases">Read the cases →</a>
        <a href="https://github.com/NicolasAndresCalvo">GitHub</a>
        <a href="https://www.linkedin.com/in/nicolas-andres-calvo/">LinkedIn</a>
      </p>
    </div>
    <img class="hero__photo" src="/profile.jpg" width="180" height="180" alt="Nicolás Andrés Calvo" />
  </section>

  <section class="section">
    <h2>Worked with</h2>
    <ul class="logos">
      {companies.map((c) => (
        <li>
          {c.url
            ? <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
            : <span>{c.name}</span>}
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <h2>Featured cases</h2>
    {featured.length === 0 ? (
      <p>No published cases yet. Run <code>npm run sync</code> to pull them from the workshop.</p>
    ) : (
      <ul class="case-list">
        {featured.map((c) => (
          <li class="case-card">
            <a class="title" href={`/cases/${c.id}`}>{c.data.title}</a>
            {c.data.summary && <p class="summary">{c.data.summary}</p>}
            <div class="case-meta">
              <span>{fmt(c.data.date)}</span>
              {c.data.client && <span>· {c.data.client}</span>}
              {c.data.draft && <span class="draft-badge">draft</span>}
              {c.data.tags.slice(0, 4).map((t) => <a class="tag" href={`/tags/${t}`}>{t}</a>)}
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="certstrip">
    <div class="certstrip__head">
      <span><strong>CNCF Kubestronaut</strong> · {activeCerts.length} active certifications</span>
      <a href="/certifications">View all →</a>
    </div>
    <ul class="certstrip__row">
      {activeCerts.map((c) => (
        <li><a href={c.url} title={c.name}><img src={c.image} width="52" height="52" loading="lazy" alt={c.name} /></a></li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
  .hero__text { flex: 1; min-width: 280px; }
  .hero__photo { border-radius: var(--radius); object-fit: cover; width: 180px; height: 180px; border: 2px solid var(--border); flex-shrink: 0; }

  .logos { list-style: none; padding: 0; margin: .8rem 0 0; display: flex; flex-wrap: wrap; gap: .6rem .9rem; align-items: center; }
  .logos li a, .logos li span { display: inline-block; border: 1px solid var(--border); border-radius: 999px; padding: .4rem 1rem; color: var(--fg-muted); font-weight: 600; font-size: .95rem; transition: color .15s, border-color .15s; }
  .logos li a:hover { color: var(--accent); border-color: var(--accent); text-decoration: none; }

  .certstrip { border: 1px solid var(--border); background: var(--bg-soft); border-radius: var(--radius); padding: 1rem 1.2rem; margin-top: 1rem; }
  .certstrip__head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; font-size: .9rem; color: var(--fg-muted); }
  .certstrip__row { list-style: none; display: flex; flex-wrap: wrap; gap: .6rem; padding: 0; margin: .9rem 0 0; }
  .certstrip__row img { object-fit: contain; transition: transform .12s; }
  .certstrip__row a:hover img { transform: scale(1.12); }
</style>
