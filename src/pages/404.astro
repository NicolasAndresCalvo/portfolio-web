---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 · Nicolás Andrés Calvo" description="Page not found.">
  <section class="notfound">
    <p class="code">404</p>
    <h1>Page not found</h1>
    <p class="msg">This page doesn't exist or has moved.</p>
    <p class="links">
      <a href="/">← Back home</a>
      <a href="/cases">Cases</a>
      <a href="/certifications">Certifications</a>
    </p>
  </section>
</BaseLayout>

<style>
  .notfound { padding: 5rem 0; text-align: center; }
  .code { font-size: 5rem; font-weight: 800; margin: 0; color: var(--accent); line-height: 1; }
  .notfound h1 { font-size: 1.6rem; margin: .5rem 0; }
  .msg { color: var(--fg-muted); }
  .links { margin-top: 1.5rem; }
  .links a { margin: 0 .6rem; }
</style>
